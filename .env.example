# Copy to .env and fill in your values

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Models (defaults shown)
EMBEDDING_MODEL=gemini-embedding-2-preview
VISION_MODEL=gemini-2.0-flash

# Storage (CHROMA_PERSIST_DIR is reused as the vector store directory name)
CHROMA_PERSIST_DIR=./vector_store
COLLECTION_NAME=image_search

# Ingestion
IMAGES_DIR=./images
IMAGE_MAX_PX=1024          # resize images to max this dimension before embedding

# Search
TOP_K=10

# Rate limiting (adjust to your Gemini quota tier)
# Free tier: ~15 RPM  |  Pay-as-you-go: ~1000 RPM
RATE_LIMIT_RPM=60

# Set to "true" to also generate text descriptions per image (adds 1 API call/image)
GENERATE_DESCRIPTIONS=false
